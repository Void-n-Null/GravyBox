# Normalize line endings: LF in the repo, auto on checkout.
* text=auto eol=lf

# Treat known source as text explicitly.
*.cs        text diff=csharp
*.rs        text
*.godot     text
*.tscn      text
*.tres      text
*.import    text
*.cfg       text
*.md        text

# Binary asset types (no diff/merge). Candidates for Git LFS later if they grow.
*.png       binary
*.jpg       binary
*.glb       binary
*.stl       binary
*.3mf       binary
